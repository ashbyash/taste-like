# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HuggingFace (embedding)
HF_SPACE_URL=https://your-space.hf.space
HF_SPACE_API_KEY=your-hf-space-api-key
HF_TOKEN=hf_your-token

# OpenAI (fashion description)
OPENAI_API_KEY=sk-your-openai-key

# Cron & Telegram
CRON_SECRET=your-cron-secret
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Site
NEXT_PUBLIC_SITE_URL=https://taste-like.vercel.app

# GitHub (on-demand crawl triggers via Actions)
GITHUB_PAT=ghp_your-personal-access-token

# Miu Miu (Algolia)
MIUMIU_ALGOLIA_APP_ID=your-algolia-app-id
MIUMIU_ALGOLIA_API_KEY=your-algolia-api-key
MIUMIU_ALGOLIA_INDEX=PLP_COLOR_MIUMIU_Online_KR
